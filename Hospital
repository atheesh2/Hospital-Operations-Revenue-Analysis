CREATE DATABASE Hospitall;
USE Hospitall;

CREATE TABLE Patients (
    patient_id INT PRIMARY KEY AUTO_INCREMENT,
    patient_name VARCHAR(100),
    age INT,
    gender VARCHAR(10),
    blood_type VARCHAR(5),
    city VARCHAR(100)
);

CREATE TABLE Hospitals (
    hospital_id INT PRIMARY KEY AUTO_INCREMENT,
    hospital_name VARCHAR(100)
);

CREATE TABLE Doctors (
    doctor_id INT PRIMARY KEY AUTO_INCREMENT,
    doctor_name VARCHAR(100),
    hospital_id INT,
    specialization VARCHAR(250),
    experience_years INT,
    consultation_fee INT,
    FOREIGN KEY (hospital_id)
        REFERENCES Hospitals(hospital_id)
);

UPDATE Doctors
SET hospital_id = FLOOR(1 + RAND() * 30);

CREATE TABLE Appointments (
    appointment_id INT PRIMARY KEY AUTO_INCREMENT,
    patient_id INT NOT NULL,
    doctor_id INT NOT NULL,
    appointment_date DATE,
    appointment_time TIME,
    reason_for_visit VARCHAR(255),
    status VARCHAR(50),
    FOREIGN KEY (patient_id)
        REFERENCES Patients(patient_id),
    FOREIGN KEY (doctor_id)
        REFERENCES Doctors(doctor_id)
);

CREATE TABLE Billing (
    bill_id INT PRIMARY KEY AUTO_INCREMENT,
    appointment_id INT,
    amount DECIMAL(10,2),
    payment_method VARCHAR(100),
    payment_status VARCHAR(250),
    FOREIGN KEY (appointment_id)
        REFERENCES Appointments(appointment_id)
);

CREATE TABLE Medications (
    medication_id INT PRIMARY KEY AUTO_INCREMENT,
    appointment_id INT,
    medication_name VARCHAR(100),
    test_result VARCHAR(50),
    description VARCHAR(250),
    cost INT,
    treatment_date DATE,
    FOREIGN KEY (appointment_id)
        REFERENCES Appointments(appointment_id)
);

SELECT COUNT(*) AS total_patients
FROM Patients;

SELECT gender, COUNT(*) AS count
FROM Patients
GROUP BY gender;

SELECT AVG(age) AS avg_age
FROM Patients;

SELECT blood_type, COUNT(*) AS count
FROM Patients
GROUP BY blood_type;

SELECT reason_for_visit, COUNT(*) AS patient_count
FROM Appointments
GROUP BY reason_for_visit;

SELECT COUNT(*) AS total_doctors
FROM Doctors;

SELECT d.doctor_name,
       COUNT(a.appointment_id) AS patient_count
FROM Doctors d
JOIN Appointments a
ON d.doctor_id = a.doctor_id
GROUP BY d.doctor_id
ORDER BY patient_count DESC;

SELECT d.doctor_name,
       SUM(d.consultation_fee) AS total_consultation_revenue
FROM Doctors d
JOIN Appointments a
ON d.doctor_id = a.doctor_id
GROUP BY d.doctor_id;

SELECT doctor_name,
       specialization,
       experience_years,
       RANK() OVER(ORDER BY experience_years DESC) AS exp_rank
FROM Doctors;

SELECT d.doctor_name,
       COUNT(a.appointment_id) / COUNT(DISTINCT a.appointment_date) AS avg_daily_workload
FROM Doctors d
JOIN Appointments a
ON d.doctor_id = a.doctor_id
GROUP BY d.doctor_id;

SELECT COUNT(*) AS total_hospitals
FROM Hospitals;

SELECT h.hospital_name,
       SUM(b.amount) AS hospital_revenue
FROM Hospitals h
JOIN Doctors d
ON h.hospital_id = d.hospital_id
JOIN Appointments a
ON d.doctor_id = a.doctor_id
JOIN Billing b
ON a.appointment_id = b.appointment_id
GROUP BY h.hospital_id
ORDER BY hospital_revenue DESC;

SELECT h.hospital_name,
       COUNT(a.appointment_id) AS total_admissions
FROM Hospitals h
JOIN Doctors d
ON h.hospital_id = d.hospital_id
JOIN Appointments a
ON d.doctor_id = a.doctor_id
GROUP BY h.hospital_id;

SELECT h.hospital_name,
       SUM(b.amount) AS revenue
FROM Hospitals h
JOIN Doctors d
ON h.hospital_id = d.hospital_id
JOIN Appointments a
ON d.doctor_id = a.doctor_id
JOIN Billing b
ON a.appointment_id = b.appointment_id
GROUP BY h.hospital_id
ORDER BY revenue DESC
LIMIT 1;

SELECT h.hospital_name,
       COUNT(a.appointment_id) AS volume,
       DENSE_RANK() OVER(ORDER BY COUNT(a.appointment_id) DESC) AS performance_rank
FROM Hospitals h
JOIN Doctors d
ON h.hospital_id = d.hospital_id
JOIN Appointments a
ON d.doctor_id = a.doctor_id
GROUP BY h.hospital_id;

SELECT COUNT(*) AS total_appointments
FROM Appointments;

SELECT DATE_FORMAT(appointment_date, '%Y-%m') AS month,
       COUNT(*) AS count
FROM Appointments
GROUP BY month;

SELECT status,
       COUNT(*) AS count
FROM Appointments
GROUP BY status;

SELECT AVG(cost) AS avg_med_cost
FROM Medications;

SELECT appointment_id,
       SUM(cost) AS total_med_cost
FROM Medications
GROUP BY appointment_id
ORDER BY total_med_cost DESC
LIMIT 5;

SELECT SUM(amount) AS gross_revenue
FROM Billing;

SELECT payment_method,
       SUM(amount) AS total
FROM Billing
GROUP BY payment_method;

SELECT AVG(amount) AS avg_bill
FROM Billing;

SELECT MAX(amount) AS max_bill
FROM Billing;

SELECT DATE_FORMAT(a.appointment_date, '%Y-%m') AS month,
       SUM(b.amount) AS monthly_rev
FROM Billing b
JOIN Appointments a
ON b.appointment_id = a.appointment_id
GROUP BY month;

WITH DocRev AS (
    SELECT doctor_id,
           SUM(amount) AS total_rev
    FROM Billing b
    JOIN Appointments a
    ON b.appointment_id = a.appointment_id
    GROUP BY doctor_id
)
SELECT doctor_id,
       total_rev
FROM DocRev
WHERE total_rev > (
    SELECT AVG(total_rev)
    FROM DocRev
);

WITH PatientVisits AS (
    SELECT patient_id,
           COUNT(appointment_id) AS visit_count
    FROM Appointments
    GROUP BY patient_id
)
SELECT p.patient_name,
       v.visit_count
FROM Patients p
JOIN PatientVisits v
ON p.patient_id = v.patient_id
WHERE v.visit_count > 3;

SELECT d.doctor_name,
       d.specialization,
       SUM(b.amount) AS revenue,
       RANK() OVER(PARTITION BY d.specialization ORDER BY SUM(b.amount) DESC) AS spec_rank
FROM Doctors d
JOIN Appointments a
ON d.doctor_id = a.doctor_id
JOIN Billing b
ON a.appointment_id = b.appointment_id
GROUP BY d.doctor_id,
         d.specialization;

SELECT appointment_date,
       SUM(amount) AS daily_rev,
       SUM(SUM(amount)) OVER(ORDER BY appointment_date) AS running_total
FROM Billing b
JOIN Appointments a
ON b.appointment_id = a.appointment_id
GROUP BY appointment_date;

WITH MonthlyRev AS (
    SELECT DATE_FORMAT(appointment_date, '%Y-%m') AS month,
           SUM(amount) AS revenue
    FROM Billing b
    JOIN Appointments a
    ON b.appointment_id = a.appointment_id
    GROUP BY month
)
SELECT month,
       revenue,
       LAG(revenue) OVER(ORDER BY month) AS prev_month_rev,
       (revenue - LAG(revenue) OVER(ORDER BY month)) AS growth
FROM MonthlyRev;
